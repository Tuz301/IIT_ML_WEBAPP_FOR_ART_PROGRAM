# IIT ML Service - Frontend Environment Configuration Example
# Copy this file to .env.local and update with your values

# =============================================================================
# API Configuration
# =============================================================================
# Backend API URL (for development, use http://localhost:8000)
VITE_API_URL=http://localhost:8000
# API version prefix
VITE_API_VERSION=v1

# =============================================================================
# CDN Configuration
# =============================================================================
# Enable CDN for static assets (set to true in production)
VITE_CDN_ENABLED=false
# CDN base URL (e.g., https://cdn.yourdomain.com)
VITE_CDN_URL=
# CDN URLs for specific asset types
VITE_CDN_IMAGES_URL=
VITE_CDN_FONTS_URL=
VITE_CDN_CSS_URL=
VITE_CDN_JS_URL=

# Cache duration for different asset types (in seconds)
VITE_CDN_CACHE_IMAGES=31536000
VITE_CDN_CACHE_FONTS=31536000
VITE_CDN_CACHE_CSS=86400
VITE_CDN_CACHE_JS=86400

# =============================================================================
# Application Configuration
# =============================================================================
# Application title
VITE_APP_TITLE=IIT ML Service
# Application version
VITE_APP_VERSION=1.0.0
# Enable debug mode (set to false in production)
VITE_DEBUG=true

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable features
VITE_FEATURE_PREDICTIONS=true
VITE_FEATURE_PATIENT_MANAGEMENT=true
VITE_FEATURE_REPORTS=true
VITE_FEATURE_DASHBOARD=true

# =============================================================================
# Authentication Configuration
# =============================================================================
# Session timeout in minutes
VITE_SESSION_TIMEOUT=30
# Enable remember me functionality
VITE_ENABLE_REMEMBER_ME=true

# =============================================================================
# UI Configuration
# =============================================================================
# Default theme (light, dark, system)
VITE_DEFAULT_THEME=system
# Enable theme toggle
VITE_ENABLE_THEME_TOGGLE=true
# Default language
VITE_DEFAULT_LANGUAGE=en

# =============================================================================
# Analytics Configuration (Optional)
# =============================================================================
# Google Analytics ID
VITE_GA_ID=
# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# Error Reporting (Optional)
# =============================================================================
# Sentry DSN for frontend error tracking
VITE_SENTRY_DSN=
# Sentry environment
VITE_SENTRY_ENVIRONMENT=development
# Sentry sample rate (0.0 to 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Map Configuration (Optional)
# =============================================================================
# Mapbox access token
VITE_MAPBOX_TOKEN=
# Google Maps API key
VITE_GOOGLE_MAPS_KEY=

# =============================================================================
# File Upload Configuration
# =============================================================================
# Maximum file size in MB
VITE_MAX_FILE_SIZE=10
# Allowed file types (comma-separated)
VITE_ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf,.doc,.docx

# =============================================================================
# Pagination Configuration
# =============================================================================
# Default page size
VITE_DEFAULT_PAGE_SIZE=20
# Maximum page size
VITE_MAX_PAGE_SIZE=100

# =============================================================================
# Date/Time Configuration
# =============================================================================
# Default date format
VITE_DATE_FORMAT=YYYY-MM-DD
# Default time format
VITE_TIME_FORMAT=HH:mm:ss
# Timezone
VITE_TIMEZONE=UTC
